# aws-telephony-bot - Environment Variables
# Copy this file to .env and fill in your API keys

# Daily (Transport)
DAILY_API_KEY=

# Environment mode: "local" for development, "production" for cloud deployment
ENV=local

# Local bot server URL (where bot.py runs)
LOCAL_SERVER_URL=http://localhost:7860

# Pipecat Cloud (only needed for production)
PIPECAT_API_KEY=
PIPECAT_AGENT_NAME=aws-telephony-bot

# AWS (STT/LLM/TTS/Realtime)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_BEDROCK_MODEL=
AWS_SESSION_TOKEN=


# Deepgram (STT/TTS)
DEEPGRAM_API_KEY=
DEEPGRAM_VOICE_ID= # "aura-2-helena-en"

# Deepgram on SageMaker (STT/TTS)
# Subscribe to Deepgram on AWS Marketplace, then find model package ARNs in
# SageMaker console under "Model packages > AWS Marketplace subscriptions".
# STT: https://aws.amazon.com/marketplace/pp/prodview-pnd4oy3p2xtro
# TTS: https://aws.amazon.com/marketplace/pp/prodview-o2f7xiwm7khdk
SAGEMAKER_EXECUTION_ROLE_ARN=
DEEPGRAM_STT_MODEL_PACKAGE_ARN=
DEEPGRAM_TTS_MODEL_PACKAGE_ARN=
SAGEMAKER_STT_ENDPOINT_NAME=deepgram-stt
SAGEMAKER_TTS_ENDPOINT_NAME=deepgram-tts
SAGEMAKER_STT_INSTANCE_TYPE=ml.g5.2xlarge
SAGEMAKER_TTS_INSTANCE_TYPE=ml.g5.2xlarge
